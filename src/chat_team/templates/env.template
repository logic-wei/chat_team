# chat_team secrets.
#
# Seeded into ~/.chat_team/.env on first run (mode 0600).
# NEVER commit the user copy. This template ships empty.

# WeCom AI Bot — long-connection credentials from the bot admin console.
WECOM_BOT_ID=
WECOM_SECRET=

# OpenAI-compatible endpoint. Set OPENAI_BASE_URL to point at a proxy / local
# vLLM / Ollama gateway if you don't want to hit api.openai.com directly.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
